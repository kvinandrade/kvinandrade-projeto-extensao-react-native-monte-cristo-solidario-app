# Firebase Configuration
# Obtenha estas credenciais em: https://console.firebase.google.com/

REACT_APP_FIREBASE_API_KEY=SEU_API_KEY_AQUI
REACT_APP_FIREBASE_AUTH_DOMAIN=SEU_PROJETO.firebaseapp.com
